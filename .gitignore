# =============================================
# OneBase .gitignore
# =============================================

# ── OS ──
.DS_Store
Thumbs.db
Desktop.ini
*:Zone.Identifier

# ── Editors / IDEs ──
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── Environment / secrets ──
.env
.env.*
!.env.example

# ── Node / Frontend ──
node_modules/
dist/
dist-ssr/
*.local
.cache/
.parcel-cache/
.turbo/
*.tsbuildinfo

# ── Python / Backend ──
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ── Test artifacts ──
backend/test.db
backend/test.db-wal
backend/test.db-shm

# ── Uploads (runtime data) ──
backend/uploads/

# ── Docker ──
*.pid

# ── Logs ──
*.log
logs/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Build output ──
build/
target/
vendor/

# ── GSD: Runtime / Ephemeral (per-developer, per-session) ──
.gsd/auto.lock
.gsd/completed-units.json
.gsd/STATE.md
.gsd/metrics.json
.gsd/activity/
.gsd/runtime/
.gsd/worktrees/
.gsd/milestones/**/continue.md
.gsd/milestones/**/*-CONTINUE.md

# ── Other tools ──
.opencode/
tmp/
