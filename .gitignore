# =============================================
# OneBase .gitignore
# =============================================

# ── OS ──
.DS_Store
Thumbs.db
Desktop.ini
*:Zone.Identifier

# ── Editors / IDEs ──
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── Environment / secrets ──
.env
.env.*
!.env.example

# ── Node / Frontend ──
node_modules/
dist/
dist-ssr/
*.local
.cache/
.parcel-cache/
.turbo/
*.tsbuildinfo

# ── Python / Backend ──
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ── Celery / Redis runtime ──
celerybeat-schedule*
dump.rdb

# ── Test artifacts ──
backend/test.db
backend/test.db-wal
backend/test.db-shm

# ── Uploads & local data ──
backend/uploads/
backend/data/uploads/
data/

# ── ML model artifacts ──
backend/ml_models/

# ── CSV data files (allow test fixtures) ──
*.csv
!**/tests/**/*.csv
!**/fixtures/**/*.csv

# ── Design assets (not source) ──
frontend/mockup-design.html
original-*.webp

# ── Docker ──
*.pid

# ── Logs ──
*.log
logs/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Build output ──
build/
target/
vendor/

# ── Local documentation (not tracked) ──
docs/pfe/
docs/rapport/
docs/revamp/
revamp.md

.playwright-cli/
tmp/
