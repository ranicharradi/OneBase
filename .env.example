# OneBase environment template. Copy to .env and fill in real values.
# Required values are marked REQUIRED; their absence will fail-fast at startup
# in production (ENVIRONMENT=production), but dev will boot with placeholders.

# REQUIRED — generate strong values before shipping:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
POSTGRES_PASSWORD=changeme
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Defaults to "production" in docker-compose.yml — override here to development
# while iterating locally so validate_production_secrets doesn't refuse to boot
# on the placeholder JWT_SECRET above.
ENVIRONMENT=development

DATABASE_URL=postgresql://onebase:changeme@postgres:5432/onebase
REDIS_URL=redis://redis:6379/0
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- AI (Phase 1) — Google Gemini via google-genai ---
LLM_ENABLED=false
LLM_API_KEY=                       # Free key from aistudio.google.com
LLM_MODEL=gemini-3-flash-preview   # or gemini-3.1-flash-lite for higher RPD
LLM_REQUEST_TIMEOUT_S=15
